{
  "python.defaultInterpreterPath": "${workspaceFolder}/backend/.venv/bin/python",
  "python.testing.pytestEnabled": true,
  "python.testing.pytestArgs": [
    "src/backend/tests"
  ],
  "python.envFile": "${workspaceFolder}/backend/.env",
  "files.exclude": {
    "**/.pytest_cache": true,
    "**/__pycache__": true,
    "**/.ruff_cache": true
  }
}
