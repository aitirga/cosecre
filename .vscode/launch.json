{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Cosecre: Open frontend",
      "type": "pwa-chrome",
      "request": "launch",
      "url": "http://127.0.0.1:5173",
      "webRoot": "${workspaceFolder}/frontend",
      "preLaunchTask": "Cosecre: Frontend dev"
    },
    {
      "name": "Cosecre: Backend (debugpy)",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "cwd": "${workspaceFolder}/backend",
      "python": "${workspaceFolder}/backend/.venv/bin/python",
      "args": [
        "backend.main:app",
        "--host",
        "0.0.0.0",
        "--port",
        "8000",
        "--reload"
      ],
      "envFile": "${workspaceFolder}/backend/.env"
    }
  ],
  "compounds": [
    {
      "name": "Cosecre: Full stack",
      "configurations": [
        "Cosecre: Backend (debugpy)",
        "Cosecre: Open frontend"
      ]
    }
  ]
}
